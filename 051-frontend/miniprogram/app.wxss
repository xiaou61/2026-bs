page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
}

.container {
  padding: 20rpx;
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-primary {
  color: #1890ff;
}

.text-success {
  color: #52c41a;
}

.text-warning {
  color: #faad14;
}

.text-danger {
  color: #ff4d4f;
}

.text-gray {
  color: #999;
}

.text-small {
  font-size: 24rpx;
}

.btn-primary {
  background-color: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  padding: 16rpx 32rpx;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.8;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.avatar-small {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.avatar-placeholder,
.category-icon-placeholder,
.placeholder-cover,
.banner-card {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1d7afc 0%, #13c2c2 100%);
  color: #fff;
  font-weight: 600;
}

.category-icon-placeholder {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  font-size: 34rpx;
}

.placeholder-cover {
  font-size: 28rpx;
}

.banner-card {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  font-size: 38rpx;
  letter-spacing: 2rpx;
}

.banner-card-alt {
  background: linear-gradient(135deg, #fa8c16 0%, #f5222d 100%);
}
