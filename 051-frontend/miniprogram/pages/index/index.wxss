/* 顶部横幅 */
.header-banner {
  position: relative;
  height: 240rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1565C0 0%, #42A5F5 50%, #64B5F6 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 20rpx;
}

.header-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  letter-spacing: 6rpx;
}

/* 轮播图 */
.banner {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.custom-swiper {
  height: 280rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(21, 101, 192, 0.15);
}

.banner-card {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1565C0 0%, #42A5F5 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
}

.banner-card-alt {
  background: linear-gradient(135deg, #E65100 0%, #FF9800 100%);
}

.banner-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.banner-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 4rpx;
}

/* 分类区域 */
.category-section {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin: 30rpx 0 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #333;
}

.title-icon {
  font-size: 36rpx;
}

.title-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.more {
  font-size: 26rpx;
  font-weight: normal;
  color: #1565C0;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(21, 101, 192, 0.1);
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.category-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #1565C0, #42A5F5);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(21, 101, 192, 0.2);
}

.category-icon-wrap image {
  width: 56rpx;
  height: 56rpx;
}

.category-icon-placeholder {
  font-size: 40rpx;
}

.category-item text {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* 文章列表 */
.article-section {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.article-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.article-item {
  display: flex;
  padding: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.article-cover-wrap {
  flex-shrink: 0;
  width: 200rpx;
  height: 140rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.article-cover {
  width: 100%;
  height: 100%;
}

.placeholder-cover {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-icon {
  font-size: 48rpx;
}

.article-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.article-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.meta-tag {
  font-size: 20rpx;
  color: #1565C0;
  background: #E3F2FD;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: #999;
}

.meta-icon {
  font-size: 24rpx;
}

/* 安全小贴士 */
.tips-section {
  padding: 0 24rpx;
  margin-bottom: 40rpx;
}

.tips-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  border-radius: 16rpx;
  border-left: 8rpx solid #FF9800;
}

.tips-icon {
  font-size: 36rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #E65100;
  font-weight: 500;
}
