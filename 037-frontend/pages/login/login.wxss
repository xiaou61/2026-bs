/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #6C63FF 0%, #3F3D56 50%, #232136 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 60rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 装饰背景圆 */
.bg-circles {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(108, 99, 255, 0.15);
}

.circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -80rpx;
  right: -60rpx;
  animation: float1 6s ease-in-out infinite;
}

.circle-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: 200rpx;
  left: -40rpx;
  animation: float2 8s ease-in-out infinite;
}

.circle-3 {
  width: 150rpx;
  height: 150rpx;
  top: 40%;
  right: 10%;
  background: rgba(255, 193, 7, 0.15);
  animation: float3 7s ease-in-out infinite;
}

@keyframes float1 {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-30rpx) scale(1.05); }
}

@keyframes float2 {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(10deg); }
}

@keyframes float3 {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(-15rpx, -15rpx); }
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-bottom: 80rpx;
  position: relative;
  z-index: 2;
}

.logo-badge {
  width: 180rpx;
  height: 180rpx;
  line-height: 180rpx;
  margin: 0 auto 40rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #6C63FF 0%, #FF6584 100%);
  box-shadow: 0 20rpx 60rpx rgba(108, 99, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-15rpx); }
}

.logo-icon {
  font-size: 80rpx;
}

.app-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.slogan {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 6rpx;
}

/* 功能特色 */
.features {
  display: flex;
  justify-content: space-around;
  width: 100%;
  margin-bottom: 80rpx;
  position: relative;
  z-index: 2;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  backdrop-filter: blur(10px);
  min-width: 180rpx;
}

.feature-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.feature-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

/* 登录区域 */
.login-section {
  width: 100%;
  position: relative;
  z-index: 2;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #F5F5F5 100%);
  color: #333333;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
  border: none;
  letter-spacing: 4rpx;
}

.login-btn::after {
  border: none;
}

.wx-icon-wrap {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  background: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wx-icon {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
}

.btn-text {
  color: #333;
}

.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  padding: 0 20rpx;
}

.agreement checkbox {
  margin-right: 8rpx;
  transform: scale(0.8);
}

.agreement-text {
  color: rgba(255, 255, 255, 0.7);
}

.agreement .link {
  color: #FFD54F;
  font-weight: 500;
}

/* 底部装饰 */
.bottom-decoration {
  position: fixed;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 2;
}

.code-icon {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.3);
  font-weight: 700;
  font-family: monospace;
  margin-bottom: 12rpx;
}

.version {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 2rpx;
}
