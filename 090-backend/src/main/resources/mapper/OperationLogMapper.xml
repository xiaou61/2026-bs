<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.opera.mapper.OperationLogMapper">

    <insert id="insert" parameterType="OperationLog" useGeneratedKeys="true" keyProperty="id">
        insert into operation_log (user_id, module, action, content)
        values (#{userId}, #{module}, #{action}, #{content})
    </insert>

</mapper>

